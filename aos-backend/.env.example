# ============================================================
# AOS Backend Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# App
APP_NAME=AOS
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
SECRET_KEY=your-secret-key-change-in-production
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://aos_user:aos_password@localhost:5432/aos_db
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET_KEY=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
PRIMARY_LLM_MODEL=claude-sonnet-4-6
FALLBACK_LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# WhatsApp (Meta Cloud API)
WHATSAPP_API_URL=https://graph.facebook.com/v21.0
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-token
WHATSAPP_VERIFY_TOKEN=your-verify-token

# GST / E-Invoice
GST_API_URL=https://gsp.api.example.com
GST_API_KEY=your-gst-api-key
E_INVOICE_API_URL=https://einv-apisandbox.nic.in
E_INVOICE_USERNAME=your-einv-username
E_INVOICE_PASSWORD=your-einv-password

# Banking
BANK_API_URL=https://api.bank.example.com
BANK_API_KEY=your-bank-api-key

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=aos-documents

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# OCR
OCR_PROVIDER=textract
# OCR_PROVIDER=google_document_ai

# Observability
LOG_LEVEL=INFO
SENTRY_DSN=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
